            },
            {
              "id": "rejected-msg",
              "name": "message",
              "value": "Portfolio report rejected by advisor. Not stored.",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "b2c3d4e5-0002-0002-0002-000000000010",
      "name": "Log Rejection",
      "type": "n8n-nodes-base.set",
