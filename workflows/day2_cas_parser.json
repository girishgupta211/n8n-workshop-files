              "type": "number"
            },
            {
              "id": "approved-xirr",
              "name": "overall_xirr",
              "value": "={{ $node['Compute Portfolio Summary'].json.summary.overall_xirr }}",
              "type": "number"
            },
            {
              "id": "approved-at",
              "name": "approved_at",
              "value": "={{ $now }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "b2c3d4e5-0002-0002-0002-000000000009",
      "name": "Format Approved Record",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1940, 220]
    },
    {
