        "mode": "runOnceForAllItems",
  "jsCode": "const items = $input.all();\nconst publicDetails = $('Fetch Public Details (NAV History)').first().json.body || $('Fetch Public Details (NAV History)').first().json || {};\n\nconst meta = publicDetails.meta || {};\nconst rawData = publicDetails.data || [];\n\nconst navHistory = rawData.map(n => ({\n  date: n.date,\n  nav: parseFloat(n.nav) || 0\n}));\n\nconst output = {\n  scheme_code: String(meta.scheme_code || \"\"),\n  isin: String(meta.scheme_isin || meta.isin || \"\"),\n  amc_name: meta.fund_house || meta.amc_name || \"\",\n  name: meta.scheme_name || \"\",\n  nav_history: navHistory,\n  enriched: false,\n  holdings: [],\n  aum: null,\n  expense_ratio: null,\n  risk_metrics: {\n    sharpe: null,\n    beta: null,\n    alpha: null,\n    std_dev: null\n  },\n  factsheet_url: null\n};\n\nreturn [{ json: output }];"
      }
