    {
      "id": "unified-parser-premium-node",
      "name": "Unified Output Parser (Premium)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        50
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
  "jsCode": "const items = $input.all();\nconst premiumEnvelope = $('Fetch Scheme Detail (Premium)').first().json.body || $('Fetch Scheme Detail (Premium)').first().json || {};\nconst detailResponse = premiumEnvelope.data || premiumEnvelope || {};\nconst factsheetResponse = $('Fetch Factsheet (Premium)').first().json.body?.data || $('Fetch Factsheet (Premium)').first().json.body || {};\nconst navResponse = $('Fetch NAV History (Premium)').first().json.body?.data || $('Fetch NAV History (Premium)').first().json.data || [];\n\nconst formatDate = (epochMs) => {\n  const d = new Date(epochMs);\n  const day = String(d.getDate()).padStart(2, '0');\n  const month = String(d.getMonth() + 1).padStart(2, '0');\n  const year = d.getFullYear();\n  return day + '-' + month + '-' + year;\n};\n\nconst navHistory = Array.isArray(navResponse) ? navResponse.map(n => ({\n  date: formatDate(n[0]),\n  nav: parseFloat(n[1]) || 0\n})) : [];\n\nconst mfData = detailResponse.mf_data || {};\nconst schemeList = Array.isArray(mfData.scheme) ? mfData.scheme : [];\nconst scheme0 = schemeList[0] || {};\nconst riskList = Array.isArray(mfData.risk_volatility) ? mfData.risk_volatility : [];\nconst risk3 = riskList.find((entry) => Number(entry?.period_years) === 3 || String(entry?.period_years) === '3') || riskList[0] || {};\n\nconst holdings = (mfData.equity_holdings || detailResponse.holdings || []).map(h => ({\n  security: h.holding_name || h.security_name || h.Holding_Name || h.name || \"\",\n  weight: parseFloat(h.portfolio_weight || h.weight_percent || h.Portfolio_Weight || h.weight) || 0\n}));\n\nconst aumRaw = parseFloat(scheme0.total_assets ?? scheme0.aum ?? detailResponse.aum ?? detailResponse.total_aum ?? detailResponse.Asset_Size);\nconst aum = Number.isFinite(aumRaw) ? Math.round(aumRaw / 1e7) : NaN; // convert rupees → Crores\nconst expenseRatio = parseFloat(scheme0.expense_ratio ?? detailResponse.expense_ratio ?? detailResponse.ter);\nconst riskShapre = parseFloat(risk3.sharpe_ratio ?? risk3.sharpe ?? detailResponse.risk_metrics?.sharpe_ratio ?? detailResponse.sharpe_ratio);\nconst riskBeta = parseFloat(risk3.beta ?? detailResponse.risk_metrics?.beta ?? detailResponse.beta);\nconst riskAlpha = parseFloat(risk3.alpha ?? detailResponse.risk_metrics?.alpha ?? detailResponse.alpha);\nconst riskStdDev = parseFloat(risk3.standard_deviation ?? risk3.std_dev ?? risk3.standard_deviation_pct ?? detailResponse.risk_metrics?.standard_deviation ?? detailResponse.standard_deviation);\n\nconst output = {\n  scheme_code: String(detailResponse.scheme_code || detailResponse.scheme_amfi_code || detailResponse.amfi_code || detailResponse.BSE_Code || scheme0.scheme_code || \"\"),\n  isin: String(detailResponse.scheme_isin || detailResponse.isin || detailResponse.schemeISIN || scheme0.isin || factsheetResponse.isin || \"\"),\n  amc_name: detailResponse.fund_house || detailResponse.amc_name || detailResponse.asset_manager || scheme0.fund_house || factsheetResponse.fund_name || \"\",\n  name: detailResponse.name || detailResponse.scheme_name || scheme0.scheme_name || \"\",\n  nav_history: navHistory,\n  enriched: true,\n  holdings: holdings,\n  aum: Number.isFinite(aum) ? aum : null,\n  expense_ratio: Number.isFinite(expenseRatio) ? expenseRatio : null,\n  risk_metrics: {\n    sharpe: Number.isFinite(riskShapre) ? riskShapre : null,\n    beta: Number.isFinite(riskBeta) ? riskBeta : null,\n    alpha: Number.isFinite(riskAlpha) ? riskAlpha : null,\n    std_dev: Number.isFinite(riskStdDev) ? riskStdDev : null\n  },\n  factsheet_url: factsheetResponse.factsheet_url || factsheetResponse.link || factsheetResponse.pdf_link || detailResponse.factsheet_url || null\n};\n\nreturn [{ json: output }];"
      }
