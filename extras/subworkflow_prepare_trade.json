{
  "name": "Subworkflow - Prepare Trade",
  "nodes": [
    {
      "parameters": {
        "workflowInputs": {
          "values": [
            {
              "name": "scheme_name"
            },
            {
              "name": "reallocation_pct",
              "type": "number"
            },
            {
              "name": "std_dev",
              "type": "number"
