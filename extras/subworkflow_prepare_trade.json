      },
      "id": "6636209e-7c8d-4b5b-bda2-059b428146c7",
      "name": "When Executed by Another Workflow",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1.1,
      "position": [
        -1008,
        160
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose",
            "version": 2
          },
          "combinator": "or",
          "conditions": [
            {
              "id": "cond-realloc-threshold",
              "leftValue": "={{ parseFloat($json.reallocation_pct) }}",
              "operator": {
                "type": "number",
                "operation": "gt"
              },
              "rightValue": 10
            },
            {
              "id": "cond-stddev-threshold",
              "leftValue": "={{ parseFloat($json.std_dev) > 22 || (parseFloat($json.std_dev) > 0.22 && parseFloat($json.std_dev) < 1.0) }}",
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ]
        },
        "options": {}
      },
      "id": "1fc1c39c-63f2-4ff0-b424-2e6aa26c9336",
      "name": "If High Risk (Escalate)",
